
# ─── VeriSage Pro · Environment Configuration ───────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# ─── VeriSage Pro's Own Database (SQL Server or MySQL) ───────────────────────
# Set DB_DIALECT to "mssql" or "mysql"
DB_DIALECT=mssql

DB_USER=sa
DB_PASSWORD=1234
DB_SERVER=DESKTOP-NICTN2T\MSSQLSERVER01
DB_DATABASE=VeriSagePro
DB_PORT=1433

# ─── SAGE 200 Evolution Database (On-Premise SQL Server) ─────────────────────
SAGE_DB_USER=sa
SAGE_DB_PASSWORD=1234
SAGE_DB_SERVER=DESKTOP-NICTN2T\MSSQLSERVER01
SAGE_DB_DATABASE=NIRA
SAGE_DB_PORT=1433

# ─── JWT Auth (NiRA Dashboard) ───────────────────────────────────────────────
JWT_SECRET=rubymace_mayaletissier_jayderiviere_annasandberg_hinnimiyazawa_jesspark_ellatoone_viviendermann_freyagodfrey_lisaterland
JWT_EXPIRES_IN=8h

# ─── CoCCA Webhook API Key ───────────────────────────────────────────────────
# CoCCA's platform must send this in the X-API-Key header with every POST
COCCA_API_KEY=

# ─── Income Recognition ──────────────────────────────────────────────────────
# Cron schedule for processing deferred revenue (default: midnight daily)
INCOME_RECOGNITION_CRON=0 0 * * *

# ─── Sync Retry ──────────────────────────────────────────────────────────────
# Retry attempts for a failed SAGE posting before marking as dead
MAX_RETRY_ATTEMPTS=3
RETRY_CRON=*/5 * * * *
